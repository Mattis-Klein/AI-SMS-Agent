# SMS Bridge Configuration
# COPY THIS FILE: cp .env.example .env
# SECURITY: Never commit your real .env file to git (it's in .gitignore)
# 
# For detailed documentation, see: docs/ENVIRONMENT.md

# ======== AGENT CONNECTION (Required) ========
# URL where the SMS bridge can reach the FastAPI agent
AGENT_URL=http://127.0.0.1:8787
# API key for authenticating with the agent (must match agent/.env)
AGENT_API_KEY=replace-with-the-same-key-used-by-the-agent

# ======== BRIDGE & NETWORK (Required) ========
# Port the SMS bridge listens on
BRIDGE_PORT=34567
# Public URL that Twilio webhooks call (must match Twilio Console)
# Use cloudflared: cloudflared tunnel --url http://localhost:34567
PUBLIC_BASE_URL=https://your-machine.your-tailnet.ts.net

# ======== TWILIO INTEGRATION (Required for production) ========
# Twilio Auth Token (from Twilio Console > Account > Auth Token)
# Leave empty to disable signature validation (local dev only)
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
# Comma-separated allowed senders (format: +1234567890)
# Leave empty to accept all senders
ALLOWED_SMS_FROM=+15551234567

# ======== OPENAI INTEGRATION (Optional - AI mode) ========
# OpenAI API key (from https://platform.openai.com/api-keys)
# Leave empty to disable AI mode
OPENAI_API_KEY=replace-with-your-openai-api-key
# OpenAI model to use (gpt-4.1-mini, gpt-4, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4.1-mini
# Max AI tool chaining rounds (default: 6)
AI_MAX_TOOL_ROUNDS=6

# ======== LOGGING (Optional) ========
# Max log file size in bytes before rotation (default: 1MB)
BRIDGE_LOG_MAX_BYTES=1000000