# ============================================================================
# MASHBAK - MASTER ENVIRONMENT CONFIGURATION
# ============================================================================
#
# This is the single source of truth for all Mashbak configuration variables.
# 
# INSTRUCTIONS:
#   1. Copy this file to .env.master: cp .env.master.example .env.master
#   2. Fill in your values in .env.master (NOT in this file)
#   3. Never commit .env.master to git (it's in .gitignore)
#   4. You can configure variables via chat: "EMAIL_ADDRESS = user@example.com"
#
# SECURITY: Never commit real credentials. Use .env.master for local values only.
# ============================================================================

# ============================================================================
# OPENAI / AI MODEL CONFIGURATION
# ============================================================================
# API credentials for LLM-based features like conversation summarization
# Leave OPENAI_API_KEY empty to disable AI features (fallback replies will be used)

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=25
OPENAI_TEMPERATURE=0.3

# ============================================================================
# AGENT IDENTITY & SECURITY
# ============================================================================
# Credentials used for internal backend authentication

AGENT_API_KEY=replace-with-a-long-random-secret

# ============================================================================
# DESKTOP APPLICATION
# ============================================================================
# Settings for the Mashbak desktop UI application

LOCAL_APP_PIN=
AGENT_WORKSPACE=

# ============================================================================
# EMAIL INTEGRATION (IMAP)
# ============================================================================
# Credentials and settings for inbox/email access via IMAP protocol.
# Required for email tools: list_recent_emails, summarize_inbox, etc.
#
# Canonical names:
#   EMAIL_IMAP_HOST or IMAP_SERVER (imap server hostname)
#   EMAIL_IMAP_PORT or IMAP_PORT (usually 993 for SSL)
#   EMAIL_USERNAME or EMAIL_ADDRESS (full email address or username)
#   EMAIL_PASSWORD (account password or app-specific password)
#
# When variables are missing, the assistant guides you to provide them via chat.

EMAIL_PROVIDER=generic-imap
EMAIL_IMAP_HOST=
IMAP_SERVER=
EMAIL_IMAP_PORT=993
IMAP_PORT=993
EMAIL_USERNAME=
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_MAILBOX=INBOX
EMAIL_USE_SSL=true

# ============================================================================
# SMS BRIDGE / TWILIO INTEGRATION
# ============================================================================
# Credentials for Twilio SMS service and bridge configuration
# Note: SMS bridge reads these at startup. Restart bridge after changing any SMS/Twilio vars.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
BUCHERIM_TWILIO_NUMBER=+18772683048

# Local bridge settings
BRIDGE_PORT=34567
PUBLIC_BASE_URL=
AGENT_URL=http://127.0.0.1:8787

# ============================================================================
# SMS ACCESS CONTROL
# ============================================================================
# Control which phone numbers can interact with the system via SMS
# Format: comma-separated lists or individual values

SMS_OWNER_NUMBER=
SMS_ACCESS_REQUEST_NUMBERS=
SMS_ACCESS_REQUEST_RESPONSE=
HERSHY_NUMBER=
HERSHY_RESPONSE=
REJECTED_NUMBERS=
REJECTED_RESPONSE=
SMS_DENIAL_RESPONSE=
SMS_PHONE_NORMALIZATION_DIGITS=10
SMS_ACCESS_REQUEST_KEYWORD=@mashbak
VOICE_ALLOWED_NUMBERS=
VOICE_REJECTED_RESPONSE=Sorry, this phone number is not authorized to use Mashbak voice access.

# ============================================================================
# LOGGING & DEBUG
# ============================================================================
# Control verbosity and output of system logs

LOG_LEVEL=INFO
DEBUG_MODE=false

# ============================================================================
# RUNTIME SETTINGS
# ============================================================================
# Advanced settings for backend behavior

SESSION_CONTEXT_MAX_TURNS=4
SESSION_CONTEXT_MEMORY_SIZE=50
TOOL_EXECUTION_TIMEOUT=30
MODEL_RESPONSE_MAX_TOKENS=250
