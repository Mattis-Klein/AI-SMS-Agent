# Mashbak - Agent Configuration
# COPY THIS FILE: cp .env.example .env
# SECURITY: Never commit your real .env file to git (it's in .gitignore)
# 
# For detailed documentation, see: docs/ENVIRONMENT.md

# Required: API key for authenticating bridge requests to agent
# Generate a random secret: [guid]::NewGuid().ToString() (PowerShell)
# Must match AGENT_API_KEY in sms-bridge/.env
AGENT_API_KEY=replace-with-a-long-random-secret

# Optional: Base folder for all agent file operations
# Default is auto-detected as the workspace/ folder inside the agent directory.
# Override only if you want to store runtime data in a different location.
# AGENT_WORKSPACE=C:\AI-SMS-Agent\mashbak\agent\workspace

# Required for desktop app local unlock
LOCAL_APP_PIN=5421

# Optional: enables Mashbak's shared backend assistant responses
OPENAI_API_KEY=replace-with-your-openai-api-key

# Optional model override for backend assistant responses
OPENAI_MODEL=gpt-4.1-mini

# Optional: IMAP email access for backend email tools
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_USE_SSL=true
EMAIL_USERNAME=you@example.com
EMAIL_PASSWORD=replace-with-your-email-password
EMAIL_MAILBOX=INBOX