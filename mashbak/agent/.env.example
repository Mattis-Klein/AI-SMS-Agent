# Mashbak - Agent Configuration Reference
# Reference only. Put real values in mashbak/.env.master.
# SECURITY: Never commit real secrets to git.
# 
# For detailed documentation, see: docs/ENVIRONMENT.md
#
# CONFIGURATION VIA CHAT: You can now provide most variables directly through
# the assistant chat instead of editing this file. For example, send:
#   EMAIL_ADDRESS = myemail@example.com
#   EMAIL_PASSWORD = mypassword
# The assistant will save these values automatically to mashbak/.env.master.

# Required: API key for authenticating bridge requests to agent
# Generate a random secret: [guid]::NewGuid().ToString() (PowerShell)
# Must match AGENT_API_KEY used by the bridge from mashbak/.env.master
AGENT_API_KEY=replace-with-a-long-random-secret

# Optional: Base folder for all agent file operations
# Default is auto-detected as the workspace/ folder inside the agent directory.
# Override only if you want to store runtime data in a different location.
# AGENT_WORKSPACE=C:\AI-SMS-Agent\mashbak\data\workspace

# Required for desktop app local unlock
LOCAL_APP_PIN=5421

# Optional: enables Mashbak's shared backend assistant responses
OPENAI_API_KEY=replace-with-your-openai-api-key

# Optional model override for backend assistant responses
OPENAI_MODEL=gpt-4.1-mini

# Optional: IMAP email access for backend email tools
# You can use either the EMAIL_* names below or the alias names in parentheses.
# Required values: host/server, port, username/address, password.
# Can be configured via chat: send "EMAIL_ADDRESS = email@example.com" etc.
EMAIL_PROVIDER=generic-imap
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_USE_SSL=true
EMAIL_USERNAME=you@example.com
EMAIL_PASSWORD=replace-with-your-email-password
EMAIL_MAILBOX=INBOX

# Compatibility aliases (optional; same meaning as EMAIL_* names)
# IMAP_SERVER=imap.example.com
# IMAP_PORT=993
# EMAIL_ADDRESS=you@example.com