# SMS Bridge Configuration Reference
# Reference only. Put real values in mashbak/.env.master.
# SECURITY: Never commit real secrets to git.
# 
# For detailed documentation, see: docs/ENVIRONMENT.md

# ======== AGENT CONNECTION (Required) ========
# URL where the SMS bridge can reach the FastAPI agent
AGENT_URL=http://127.0.0.1:8787
# API key for authenticating with the agent (must match mashbak/.env.master)
AGENT_API_KEY=replace-with-the-same-key-used-by-the-agent

# ======== BRIDGE & NETWORK (Required) ========
# Port the SMS bridge listens on
BRIDGE_PORT=34567
# Public URL that Twilio webhooks call (must match Twilio Console)
# Use cloudflared: cloudflared tunnel --url http://localhost:34567
PUBLIC_BASE_URL=https://your-machine.your-tailnet.ts.net

# ======== TWILIO INTEGRATION (Required for production) ========
# Twilio Account SID (used for owner notification SMS on access requests)
TWILIO_ACCOUNT_SID=replace-with-your-twilio-account-sid
# Twilio Auth Token (from Twilio Console > Account > Auth Token)
# Leave empty to disable signature validation (local dev only)
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
# Twilio number to send outbound owner notifications from (E.164 format)
# If empty, bridge falls back to webhook To number when available
TWILIO_FROM_NUMBER=+15551234567
# Twilio destination number reserved for Bucherim route matching.
BUCHERIM_TWILIO_NUMBER=+18772683048

# ======== LOGGING (Optional) ========
# Max log file size in bytes before rotation (default: 1MB)
BRIDGE_LOG_MAX_BYTES=1000000

# ======== SENDER ACCESS CONTROL (Optional but recommended) ========
# Owner number gets full forwarding access to the backend assistant.
SMS_OWNER_NUMBER=8483291230
# Comma-separated numbers that receive access-request instructions instead of forwarding.
SMS_ACCESS_REQUEST_NUMBERS=9297546860,9176355825
# Trigger keyword that asks the bridge to notify the owner.
SMS_ACCESS_REQUEST_KEYWORD=@mashbak
# Message sent to access-request numbers.
SMS_ACCESS_REQUEST_RESPONSE=This number is not authorized to use this program. To request access, send @mashbak to this number and we will review your request.
# Single number that gets a special custom response.
HERSHY_NUMBER=8457017405
# Response text for the Hershy number.
HERSHY_RESPONSE=Custom response text
# Comma-separated numbers that get the rejection response.
REJECTED_NUMBERS=4155988428,3475988428
# Message sent to rejected numbers.
REJECTED_RESPONSE=you are not authorized to use this system
# Message sent to denied numbers (not in owner, hershy, rejected, or access request lists).
SMS_DENIAL_RESPONSE=This number is not allowed.
# Optional number of digits used to normalize sender IDs (default: 10).
SMS_PHONE_NORMALIZATION_DIGITS=10
# Optional JSON file path for sender access config (relative to sms-bridge/).
# SMS_ACCESS_CONFIG_FILE=sender-access.json